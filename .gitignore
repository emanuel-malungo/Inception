# ===============================
# Inception Project - Gitignore
# ===============================

# --- Segurança (CRÍTICO) ---
.env
**/secrets/credentials.txt
**/secrets/db_password.txt
**/secrets/db_root_password.txt
secrets/*
!secrets/.gitkeep

# --- Dados do WordPress e Banco de Dados ---
data/
**/wordpress/*
**/mariadb/*

# --- Sistema e IDEs ---
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Docker ---
.docker/